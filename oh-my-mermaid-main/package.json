    "sync-version": "node scripts/sync-version.js",
    "prepublishOnly": "npm run build && npm run sync-version"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  }
}
