{
  "name": "oh-my-mermaid",
  "version": "0.2.0",
  "description": "Architecture mirror for vibe coding — CLI + Claude Code skills",
  "type": "module",
  "bin": {
    "omm": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "skills/",
    ".claude-plugin/",
    "LICENSE"
  ],
  "homepage": "https://github.com/oh-my-mermaid/oh-my-mermaid",
  "bugs": {
    "url": "https://github.com/oh-my-mermaid/oh-my-mermaid/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oh-my-mermaid/oh-my-mermaid.git"
  },
  "keywords": [
    "mermaid",
    "architecture",
    "diagram",
    "claude-code",
    "vibe-coding"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
